{
  "name": "@neotherapper/visual-kit",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "visual-kit": "bin/visual-kit"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "lint:pure": "node scripts/lint-pure-components.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "gate:security": "node scripts/test-security-headers.mjs",
    "gate:size": "node scripts/bundle-size-gate.mjs",
    "test:browser": "NODE_OPTIONS=--no-experimental-strip-types playwright test",
    "verify": "pnpm run lint:pure && pnpm run build && pnpm run test && pnpm run gate:security && pnpm run gate:size && pnpm run test:browser"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@lit-labs/ssr": "3.2.2",
    "@lit-labs/ssr-client": "1.1.7",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "chart.js": "4.4.6",
    "dompurify": "3.1.7",
    "jsdom": "25.0.1",
    "katex": "0.16.11",
    "lit": "3.2.1",
    "prismjs": "1.29.0"
  },
  "devDependencies": {
    "@playwright/test": "1.48.2",
    "@types/jsdom": "21.1.7",
    "@types/node": "22.7.4",
    "@types/prismjs": "1.26.5",
    "esbuild": "0.24.0",
    "typescript": "5.6.2",
    "vitest": "2.1.2"
  }
}
